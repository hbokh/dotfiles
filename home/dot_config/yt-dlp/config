#  yt-dlp options
# --------------- *

# Force H.264 + AAC for macOS compatibility
--format bestvideo[vcodec^=avc1]+bestaudio[ext=m4a]/bestvideo[ext=mp4]+bestaudio[ext=m4a]/best[ext=mp4]/best
--merge-output-format mp4

# output filename
-o "%(title)s.%(ext)s"

# download the video description as well
#--write-description
